DATABASE_URL='postgres://role:password@localhost:5432/db-name'
BETTER_AUTH_SECRET="Random value used by the library for encryption and generating hashes. you can use something like openssl"
# Must be the public site origin (no trailing slash). Production: https://your-domain.com — used for OAuth redirect_uri.
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID="" # Google OAuth Web Client ID
GOOGLE_CLIENT_SECRET="" # Google OAuth Web Client Secret
# In Google Cloud Console → Credentials → your Web client → Authorized redirect URIs, add:
#   {BETTER_AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# e.g. https://your-app.vercel.app/api/auth/callback/google
CHARGILY_SECRET_KEY="" # Chargily secret key (test or live)
CHARGILY_API_BASE_URL="https://pay.chargily.net/test/api/v2" # Test mode base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Public app URL for payment redirects and client-side /api fetches (use production URL on Vercel)
# NEXT_PUBLIC_BASE_PATH="" # GitHub Pages subpath only, e.g. /repo-name — must match Next basePath if set
# Optional: comma-separated emails that always see the Admin nav client-side (still need role=admin in DB for APIs)
# NEXT_PUBLIC_ADMIN_EMAILS="youcefyouyou201588@gmail.com"